<!DOCTYPE html>
<html lang="uz">
    <head>
        <meta charset="UTF-8">
            <meta name="viewport" content="width=device-width, initial-scale=1.0">
                <title>Shifrlash Tizimi | Ma'lumotlarni xavfsiz shifrlash</title>

                <meta name="google-site-verification" content="365P9ZaOkDBuS9RofKgpMu7rv5PM9dt59YTydhXdjAs" />
                <meta name="description" content="Ushbu sayt orqali matnlaringizni xavfsiz shifrlashingiz va qayta tiklashingiz mumkin. Kuchli kriptografik algoritmlar asosida ishlaydi.">
                    <meta name="keywords" content="shifrlash, cryptography, crypto.js, matnni shifrlash, xavfsizlik">
                        <meta name="author" content="Jo'rabek Rayimqulov">

                            <link rel="icon" type="image/png" href="shifr_icon.png">
                                <link rel="stylesheet" href="style.css">
                                </head>
                                <body>
                                    <div class="app">
                                        <div class="header">
                                            <h1>🔐 CRYPTO LAB</h1>
                                            <p>Shifrlash algoritmlarini o'rganish platformasi</p>
                                        </div>

                                        <nav class="nav">
                                            <button class="nav-btn active" onclick="showPanel('classic', this)">1. Klassik</button>
                                            <button class="nav-btn" onclick="showPanel('simple', this)">2. Sodda</button>
                                            <button class="nav-btn" onclick="showPanel('stegano', this)">3. Steganografiya</button>
                                            <button class="nav-btn" onclick="showPanel('dh', this)">4. Diffie-Hellman</button>
                                            <button class="nav-btn" onclick="showPanel('rsa', this)">5. RSA</button>
                                            <button class="nav-btn" onclick="showPanel('pki', this)">6. PKI</button>
                                            <button class="nav-btn" onclick="showPanel('truecrypt', this)">7. TrueCrypt uslubi</button>
                                            <button class="nav-btn" onclick="showPanel('auth', this)">8. Autentifikatsiya</button>
                                        </nav>

                                        <!-- 1. KLASSIK SHIFRLASH -->
                                        <div class="panel active" id="panel-classic">
                                            <div class="section">
                                                <div class="section-title">Klassik shifrlash algoritmlari</div>
                                                <div class="row">
                                                    <div class="field">
                                                        <label>Algoritm</label>
                                                        <select id="classic-algo" onchange="classicAlgoChange()">
                                                            <option value="caesar">Sezar shifri</option>
                                                            <option value="vigenere">Vigenère shifri</option>
                                                            <option value="atbash">Atbash shifri</option>
                                                        </select>
                                                    </div>
                                                    <div class="field" id="caesar-key-wrap">
                                                        <label>Kalit (siljish, 1–25)</label>
                                                        <input type="number" id="caesar-key" value="3" min="1" max="25">
                                                        </div>
                                                        <div class="field" id="vig-key-wrap" style="display:none">
                                                            <label>Kalit so'z</label>
                                                            <input type="text" id="vig-key" value="KEY" placeholder="masalan: SECRET">
                                                            </div>
                                                        </div>
                                                        <div class="field">
                                                            <label>Matn</label>
                                                            <textarea id="classic-input">SALOM DUNYO</textarea>
                                                        </div>
                                                        <div class="btn-row">
                                                            <button class="btn primary" onclick="classicEncrypt()">Shifrlash</button>
                                                            <button class="btn" onclick="classicDecrypt()">Deshifrlash</button>
                                                            <button class="btn" onclick="classicClear()">Tozalash</button>
                                                        </div>
                                                        <div class="result-label">Natija</div>
                                                        <div class="result-box" id="classic-result">—</div>
                                                        <div id="classic-steps"></div>
                                                    </div>
                                                </div>

                                                <!-- 2. SODDA SHIFRLASH -->
                                                <div class="panel" id="panel-simple">
                                                    <div class="section">
                                                        <div class="section-title">Sodda shifrlash algoritmlari</div>
                                                        <div class="row">
                                                            <div class="field">
                                                                <label>Algoritm</label>
                                                                <select id="simple-algo" onchange="simpleAlgoChange()">
                                                                    <option value="base64">Base64</option>
                                                                    <option value="rot13">ROT13</option>
                                                                    <option value="xor">XOR</option>
                                                                    <option value="hex">HEX kodlash</option>
                                                                    <option value="binary">Binary kodlash</option>
                                                                </select>
                                                            </div>
                                                            <div class="field" id="xor-wrap">
                                                                <label>XOR kalit (1–255)</label>
                                                                <input type="number" id="xor-key" value="42" min="1" max="255">
                                                                </div>
                                                            </div>
                                                            <div class="field">
                                                                <label>Matn</label>
                                                                <textarea id="simple-input">Salom Dunyo!</textarea>
                                                            </div>
                                                            <div class="btn-row">
                                                                <button class="btn primary" onclick="simpleEncrypt()">Shifrlash</button>
                                                                <button class="btn" onclick="simpleDecrypt()">Deshifrlash</button>
                                                            </div>
                                                            <div class="result-label">Natija</div>
                                                            <div class="result-box" id="simple-result">—</div>
                                                        </div>
                                                    </div>

                                                    <!-- 3. STEGANOGRAFIYA -->
                                                    <div class="panel" id="panel-stegano">
                                                        <div class="section">
                                                            <div class="section-title">Steganografiya — matnni matn ichiga yashirish</div>
                                                            <div class="row">
                                                                <div class="field">
                                                                    <label>Maxfiy matn (yashiriladigan)</label>
                                                                    <textarea id="steg-secret">MAXFIY XABAR</textarea>
                                                                </div>
                                                                <div class="field">
                                                                    <label>Qoplovchi matn</label>
                                                                    <textarea id="steg-cover">Bu oddiy xat. Sizga tabrik yo'llayman. Hammasi yaxshi.</textarea>
                                                                </div>
                                                            </div>
                                                            <div class="btn-row">
                                                                <button class="btn primary" onclick="stegHide()">Yashirish</button>
                                                                <button class="btn" onclick="stegReveal()">Ochish</button>
                                                            </div>
                                                            <div class="result-label">Natija</div>
                                                            <div class="result-box" id="steg-result">—</div>
                                                            <p class="hint">Unicode zero-width belgilar (U+200B, U+200C) yordamida maxfiy matn qoplovchi matnga yashiriladi</p>
                                                        </div>
                                                    </div>

                                                    <!-- 4. DIFFIE-HELLMAN -->
                                                    <div class="panel" id="panel-dh">
                                                        <div class="section">
                                                            <div class="section-title">Diffie-Hellman kalit almashinuvi protokoli</div>
                                                            <div class="row three">
                                                                <div class="field">
                                                                    <label>Tub son p</label>
                                                                    <input type="number" id="dh-p" value="23">
                                                                    </div>
                                                                    <div class="field">
                                                                        <label>Generator g</label>
                                                                        <input type="number" id="dh-g" value="5">
                                                                        </div>
                                                                        <div class="field">
                                                                            <button class="btn primary" style="margin-top:22px;width:100%" onclick="dhGenerate()">Hisoblash</button>
                                                                        </div>
                                                                    </div>
                                                                    <div id="dh-steps"></div>
                                                                </div>
                                                            </div>

                                                            <!-- 5. RSA -->
                                                            <div class="panel" id="panel-rsa">
                                                                <div class="section">
                                                                    <div class="section-title">RSA algoritmi</div>
                                                                    <div class="row">
                                                                        <div class="field">
                                                                            <label>p (tub son)</label>
                                                                            <input type="number" id="rsa-p" value="61">
                                                                            </div>
                                                                            <div class="field">
                                                                                <label>q (tub son)</label>
                                                                                <input type="number" id="rsa-q" value="53">
                                                                                </div>
                                                                            </div>
                                                                            <div class="btn-row">
                                                                                <button class="btn primary" onclick="rsaGenKeys()">Kalitlar hosil qilish</button>
                                                                            </div>
                                                                            <div id="rsa-keys"></div>
                                                                            <hr class="divider">
                                                                                <div class="field">
                                                                                    <label>Shifrlash uchun raqam (n dan kichik bo'lishi kerak)</label>
                                                                                    <input type="number" id="rsa-msg" value="42">
                                                                                    </div>
                                                                                    <div class="btn-row">
                                                                                        <button class="btn primary" onclick="rsaEncrypt()">Shifrlash (ochiq kalit)</button>
                                                                                        <button class="btn" onclick="rsaDecrypt()">Deshifrlash (yopiq kalit)</button>
                                                                                    </div>
                                                                                    <div class="result-label">Natija</div>
                                                                                    <div class="result-box" id="rsa-result">—</div>
                                                                                </div>
                                                                            </div>

                                                                            <!-- 6. PKI -->
                                                                            <div class="panel" id="panel-pki">
                                                                                <div class="section">
                                                                                    <div class="section-title">PKI — Ochiq kalitlar infratuzilmasi</div>
                                                                                    <div class="btn-row">
                                                                                        <button class="btn primary" onclick="pkiSimulate()">Simulyatsiyani boshlash</button>
                                                                                    </div>
                                                                                    <div id="pki-steps"></div>
                                                                                </div>
                                                                            </div>

                                                                            <!-- 7. TRUECRYPT USLUBI -->
                                                                            <div class="panel" id="panel-truecrypt">
                                                                                <div class="section">
                                                                                    <div class="section-title">TrueCrypt uslubida shifrlash (AES-like XOR demo)</div>
                                                                                    <div class="row">
                                                                                        <div class="field">
                                                                                            <label>Parol</label>
                                                                                            <input type="password" id="tc-pass" value="MySecretPass123">
                                                                                            </div>
                                                                                            <div class="field">
                                                                                                <label>Tuz (salt)</label>
                                                                                                <input type="text" id="tc-salt" value="SALT2024">
                                                                                                </div>
                                                                                            </div>
                                                                                            <div class="field">
                                                                                                <label>Shifrlash uchun matn</label>
                                                                                                <textarea id="tc-input">Bu maxfiy hujjat matni.</textarea>
                                                                                            </div>
                                                                                            <div class="btn-row">
                                                                                                <button class="btn primary" onclick="tcEncrypt()">Shifrlash</button>
                                                                                                <button class="btn" onclick="tcDecrypt()">Deshifrlash</button>
                                                                                            </div>
                                                                                            <div class="result-label">Kalit derivatsiyasi va natija</div>
                                                                                            <div class="result-box" id="tc-result">—</div>
                                                                                        </div>
                                                                                    </div>

                                                                                    <!-- 8. AUTENTIFIKATSIYA -->
                                                                                    <div class="panel" id="panel-auth">
                                                                                        <div class="section">
                                                                                            <div class="section-title">Autentifikatsiya tizimi — SHA-256 + Salt</div>
                                                                                            <div class="auth-tabs">
                                                                                                <button class="btn primary" id="auth-reg-btn" onclick="authTab('reg')">Ro'yxatdan o'tish</button>
                                                                                                <button class="btn" id="auth-log-btn" onclick="authTab('log')">Kirish</button>
                                                                                            </div>
                                                                                            <div id="auth-reg">
                                                                                                <div class="row">
                                                                                                    <div class="field">
                                                                                                        <label>Foydalanuvchi nomi</label>
                                                                                                        <input type="text" id="auth-user" value="ali_uzb">
                                                                                                        </div>
                                                                                                        <div class="field">
                                                                                                            <label>Parol</label>
                                                                                                            <input type="password" id="auth-pass" value="qwerty123">
                                                                                                            </div>
                                                                                                        </div>
                                                                                                        <div class="btn-row">
                                                                                                            <button class="btn primary" onclick="authRegister()">Ro'yxatdan o'tish</button>
                                                                                                        </div>
                                                                                                        <div id="auth-reg-result"></div>
                                                                                                    </div>
                                                                                                    <div id="auth-log" style="display:none">
                                                                                                        <div class="row">
                                                                                                            <div class="field">
                                                                                                                <label>Foydalanuvchi nomi</label>
                                                                                                                <input type="text" id="auth-user2" value="ali_uzb">
                                                                                                                </div>
                                                                                                                <div class="field">
                                                                                                                    <label>Parol</label>
                                                                                                                    <input type="password" id="auth-pass2" value="qwerty123">
                                                                                                                    </div>
                                                                                                                </div>
                                                                                                                <div class="btn-row">
                                                                                                                    <button class="btn primary" onclick="authLogin()">Kirish</button>
                                                                                                                </div>
                                                                                                                <div id="auth-log-result"></div>
                                                                                                            </div>
                                                                                                        </div>
                                                                                                    </div>

                                                                                                </div>

                                                                                                <script src="crypto.js"></script>
                                                                                            </body>
                                                                                        </html>